{
  "name": "@kagal/server",
  "version": "0.0.0",
  "type": "module",
  "description": "Server library for Kagal fleet management frontends",
  "author": "Alejandro Mery <amery@apptly.co>",
  "license": "MIT",
  "homepage": "https://github.com/kagal-dev/kagal/tree/main/packages/@kagal-server#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kagal-dev/kagal.git",
    "directory": "packages/@kagal-server"
  },
  "bugs": {
    "url": "https://github.com/kagal-dev/kagal/issues"
  },
  "keywords": [
    "cloudflare",
    "cloudflare-workers",
    "fleet-management",
    "kagal",
    "mtls",
    "server"
  ],
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "unbuild",
    "clean": "rimraf dist node_modules",
    "dev": "vitest watch",
    "dev:prepare": "unbuild --stub",
    "lint": "eslint --fix .",
    "lint:check": "eslint .",
    "precommit": "run-s lint type-check build test",
    "prepack": "run-s lint:check type-check build test publint",
    "publint": "publint",
    "publish:maybe": "npm view ${npm_package_name}@${npm_package_version} version 2>/dev/null && echo \"${npm_package_name}@${npm_package_version} already published\" || pnpm publish",
    "test": "vitest run",
    "type-check": "tsc --noEmit && tsc --noEmit -p tsconfig.tools.json"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260313.1",
    "@poupe/eslint-config": "^0.8.3",
    "@types/node": "^20.19.0",
    "eslint": "^9.39.4",
    "npm-run-all2": "^8.0.4",
    "publint": "^0.3.18",
    "rimraf": "^6.1.3",
    "typescript": "~5.9.3",
    "unbuild": "3.6.1",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">= 20.19.2",
    "pnpm": ">= 10.32.1"
  },
  "publishConfig": {
    "access": "public"
  }
}
