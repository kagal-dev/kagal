{
  "name": "@kagal/agent",
  "version": "0.0.0",
  "type": "module",
  "description": "Agent CLI and library for Kagal fleet management",
  "author": "Alejandro Mery <amery@apptly.co>",
  "license": "MIT",
  "homepage": "https://github.com/kagal-dev/kagal/tree/main/packages/@kagal-agent#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kagal-dev/kagal.git",
    "directory": "packages/@kagal-agent"
  },
  "bugs": {
    "url": "https://github.com/kagal-dev/kagal/issues"
  },
  "keywords": [
    "cli",
    "fleet-management",
    "iot",
    "kagal",
    "mtls"
  ],
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "bin": {
    "kagal": "./dist/cli.mjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "unbuild",
    "clean": "rimraf dist node_modules",
    "dev": "vitest watch",
    "dev:prepare": "unbuild --stub",
    "lint": "eslint --fix .",
    "lint:check": "eslint .",
    "precommit": "run-s lint type-check build test",
    "prepack": "run-s lint:check type-check build test publint",
    "publint": "publint",
    "test": "vitest run",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "citty": "^0.2.1",
    "consola": "^3.4.2"
  },
  "devDependencies": {
    "@poupe/eslint-config": "^0.8.3",
    "@types/node": "^20.19.0",
    "eslint": "^9.30.0",
    "npm-run-all2": "^8.0.4",
    "publint": "^0.3.12",
    "rimraf": "^6.1.3",
    "typescript": "~5.9.3",
    "unbuild": "3.6.1",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">= 20.19.2",
    "pnpm": ">= 10.10.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
