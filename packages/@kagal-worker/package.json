{
  "name": "@kagal/worker",
  "version": "0.0.0",
  "type": "module",
  "description": "Durable Object library for Kagal fleet management",
  "author": "Alejandro Mery <amery@apptly.co>",
  "license": "MIT",
  "homepage": "https://github.com/kagal-dev/kagal/tree/main/packages/@kagal-worker#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kagal-dev/kagal.git",
    "directory": "packages/@kagal-worker"
  },
  "bugs": {
    "url": "https://github.com/kagal-dev/kagal/issues"
  },
  "keywords": [
    "cloudflare",
    "cloudflare-workers",
    "durable-objects",
    "fleet-management",
    "iot",
    "kagal",
    "mtls",
    "websocket"
  ],
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "unbuild",
    "clean": "rimraf dist node_modules",
    "dev": "vitest watch",
    "dev:prepare": "unbuild --stub",
    "lint": "eslint --fix .",
    "lint:check": "eslint .",
    "precommit": "run-s build lint type-check test",
    "prepack": "run-s build lint:check type-check test publint",
    "prepare": "cross-test -s dist/index.mjs || unbuild --stub",
    "publint": "publint",
    "publish:maybe": "npm view ${npm_package_name}@${npm_package_version} version 2>/dev/null && echo \"${npm_package_name}@${npm_package_version} already published\" || pnpm publish",
    "test": "vitest run",
    "type-check": "run-s type-check:main type-check:tools type-check:tests",
    "type-check:main": "tsc --noEmit",
    "type-check:tests": "tsc --noEmit -p tsconfig.tests.json",
    "type-check:tools": "tsc --noEmit -p tsconfig.tools.json"
  },
  "dependencies": {
    "defu": "^6.1.4",
    "path-to-regexp": "^6.3.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.0",
    "@cloudflare/workers-types": "^4.20260506.1",
    "@kagal/cross-test": "^0.1.3",
    "@kagal/test-utils": "workspace:^",
    "@poupe/eslint-config": "^0.8.4",
    "@types/node": "^20.19.37",
    "eslint": "^9.39.4",
    "npm-run-all2": "^8.0.4",
    "publint": "^0.3.18",
    "rimraf": "^6.1.3",
    "typescript": "~5.9.3",
    "unbuild": "3.6.1",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "@cloudflare/workers-types": "^4.20260506.1"
  },
  "engines": {
    "node": ">= 20.20.1",
    "pnpm": ">= 10.32.1"
  },
  "publishConfig": {
    "access": "public"
  }
}
