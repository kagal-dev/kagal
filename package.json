{
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Agent fleet management framework over Cloudflare's edge",
  "author": "Alejandro Mery <amery@apptly.co>",
  "license": "MIT",
  "keywords": [],
  "scripts": {
    "build": "pnpm -r build",
    "clean": "pnpm -r clean && rimraf dist node_modules",
    "dev:demo-hono": "wrangler dev -c apps/demo-hono/wrangler.toml -c apps/demo-worker/wrangler.toml",
    "dev:demo-itty": "wrangler dev -c apps/demo-itty/wrangler.toml -c apps/demo-worker/wrangler.toml",
    "dev:demo-vanilla": "wrangler dev -c apps/demo-vanilla/wrangler.toml -c apps/demo-worker/wrangler.toml",
    "dev:demo-worker": "wrangler dev -c apps/demo-worker/wrangler.toml",
    "generate": "buf generate",
    "lint": "run-s lint:root lint:proto && pnpm -r lint",
    "lint:check": "run-s lint:root:check lint:proto:check && pnpm -r lint:check",
    "lint:proto": "buf format -w proto && buf lint proto",
    "lint:proto:check": "buf format -d --exit-code proto && buf lint proto",
    "lint:root": "eslint --fix --ignore-pattern 'packages/*' --ignore-pattern 'apps/*' .",
    "lint:root:check": "eslint --ignore-pattern 'packages/*' --ignore-pattern 'apps/*' .",
    "precommit": "run-s build lint type-check test",
    "prepack": "run-s lint:check && pnpm -r prepack",
    "test": "pnpm -r test",
    "type-check": "pnpm -r type-check"
  },
  "devDependencies": {
    "@bufbuild/buf": "^1.66.1",
    "@bufbuild/protoc-gen-es": "^2.11.0",
    "@poupe/eslint-config": "^0.8.4",
    "eslint": "^9.39.4",
    "npm-run-all2": "^8.0.4",
    "rimraf": "^6.1.3",
    "vitest": "^4.1.1",
    "wrangler": "^4.74.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@bufbuild/buf",
      "@bufbuild/protoc-gen-es"
    ]
  },
  "packageManager": "pnpm@10.33.1+sha512.05ba3c1d5d1c18f68df06470d74055e62d41fc110a0c660db1b2dfb2785327f04cf0f68345d4609bc52089e7fa0343c31593b2f9594e2c5d5da426230acc9820"
}
